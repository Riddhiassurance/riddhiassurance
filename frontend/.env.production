# Set this to your deployed admin panel URL (the `admin/` app on Vercel)
VITE_ADMIN_URL = 'https://riddhiassurance-admin.vercel.app'
VITE_RAZORPAY_KEY_ID = '------ Razorpay Key Id here ------'
